# Copy to .env.local for local dev, and add the same vars in your Vercel project
# (Settings → Environment Variables). With these UNSET, the app runs in local
# "demo" mode (localStorage) so the static deploy keeps working.

# --- Supabase (accounts, database, storage) ------------------------------
# Create a free project at https://supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-PUBLIC-ANON-KEY
# Server-only (used by the /api functions to grant licenses after payment).
# Project Settings → API → service_role key. NEVER expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- Stripe (card payments) ----------------------------------------------
# Dashboard → Developers → API keys. Leave blank to use instant demo licensing.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
# From the webhook endpoint you create for /api/stripe-webhook.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Copilot (LLM-backed Ask & Workspace reasoning) ----------------------
# Server-only. With this set, /api/copilot answers via Claude; with it unset the
# app uses the always-on deterministic engine. Get a key at console.anthropic.com.
ANTHROPIC_API_KEY=sk-ant-xxx
# Optional: override the model (default claude-opus-4-8; e.g. claude-sonnet-4-6).
COPILOT_MODEL=claude-opus-4-8

# --- Public dataset API (/api/datasets) ----------------------------------
# Server-only. Comma-separated list of accepted API keys (each "aec_" + 32 hex,
# as generated on the /developer page). UNSET = the public read API is OPEN
# (no key required) — fine for a demo. Set it to require a key on every request.
# API_KEYS=aec_0123...,aec_89ab...

# --- Autodesk Platform Services (native CAD/BIM: .rvt, .dwg, .nwd, …) ------
# Server-only. With both set, BIM Intelligence translates uploaded native files
# (Model Derivative → SVF2) and views them in the Autodesk Viewer. Unset = the
# connector shows setup steps and the IFC/glTF/OBJ importers still work. Create a
# free app at https://aps.autodesk.com/myapps to get the ID + secret.
APS_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
APS_CLIENT_SECRET=xxxxxxxxxxxxxxxx
